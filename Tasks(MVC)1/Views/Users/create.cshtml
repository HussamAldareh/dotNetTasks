@model Tasks_MVC_1.Models.Users

<h2>Create User</h2>

<form asp-action="Create" method="post">

    <div>
        <label>Name</label>
        <input asp-for="Name" />
    </div>

    <div>
        <label>Email</label>
        <input asp-for="Email" />
    </div>

    <div>
        <label>Password</label>
        <input name="PasswordHash" type="password" />
    </div>

    <button type="submit">Save</button>
</form>